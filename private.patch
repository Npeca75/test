+        SYNTAX      INTEGER (1..1024)
+		MAX-ACCESS  read-write
+		STATUS      current
+		DESCRIPTION 
+            "The maximum data driven learning entry value."
+        DEFVAL     { 64 }
+        ::= { igsSystem 8 }
+
+    igsReportToAllPort OBJECT-TYPE 
+        SYNTAX      INTEGER  { enabled(1), disabled(2) } 
+        MAX-ACCESS  read-write 

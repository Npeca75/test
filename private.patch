+        cpuFilterL3RuleProfileNo OBJECT-TYPE 
+           SYNTAX      Integer32 (1..5)
+           MAX-ACCESS  read-only 
+           STATUS      current 
+           DESCRIPTION 
+              "L3 Filter rule ID."
+           ::= { cpuFilterL3RuleEntry 1 }

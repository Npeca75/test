+        snmpV3GroupSecurityModel OBJECT-TYPE
+            SYNTAX    INTEGER {
+                      v1            (1),
+                      v2c	        (2),
+                      v3            (3)
+                   }
+            MAX-ACCESS   read-only
+            STATUS       current
+            DESCRIPTION "In order to gain the access rights allowed by this
+                         conceptual row, this securityModel must be in use.
+                        "
+            ::= { snmpV3GroupEntry 2 }

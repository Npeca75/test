+        cpuFilterL3RuleProtocol OBJECT-TYPE 
+           SYNTAX      INTEGER  {     
+                                         icmp(1),
+                                         igmp(2),
+                                         tcp(6),
+                                         udp(17)
+                        } 
+           MAX-ACCESS  read-write 
+           STATUS      current 
+           DESCRIPTION 
+              " The type of protocol to be checked against the packet."
+           ::= { cpuFilterL3RuleEntry 3 }

+              setting.
+
+            required(2)
+              Dialback is required for all users.
+
+            notRequired(3)
+              Dialback is not required.  It is optional on a per user basis."
+        ::= { cpqSm2CommSettingsEntry 12 }
+
+    cpqSm2CommNonPppConnections OBJECT-TYPE
+        SYNTAX  INTEGER {
+                other(1),
+                enabled(2),
+                disabled(3)
+                }
+        ACCESS  read-only
+        STATUS  mandatory
+        DESCRIPTION
+            "Non-PPP connections.
+
+            The following values are defined:
+
+            other(1)

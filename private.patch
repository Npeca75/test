+                }
+
+            dhcpBOOTPRelayInterface OBJECT-TYPE
+                SYNTAX  DisplayString (SIZE(0..12))
+                MAX-ACCESS  read-only
+                STATUS  current
+                DESCRIPTION
+                    "This object indicates the name of the IP interface."

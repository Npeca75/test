+              sessions are accepted."
+        ::= { cpqSm2CommSettingsEntry 13 }
+
+    cpqSm2CommSnmpTrapDelivery OBJECT-TYPE
+        SYNTAX  INTEGER {
+                other(1),
+                enabled(2),
+                disabled(3)
+                }

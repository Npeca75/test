+           SYNTAX      INTEGER {
+                       normal(1),
+                       underAttack(2)
+                       }
+           MAX-ACCESS  read-only 
+           STATUS      current 
+           DESCRIPTION 
+               "Use this to view per port BPDU attack protection status."
+           DEFVAL  { normal }
+           ::= { sysBPDUAttackCtrlEntry 4 }

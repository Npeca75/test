+        if (is_string($HOME_DIRECTORY)) {
+            if (!is_empty_string($HOME_DIRECTORY)) return $HOME_DIRECTORY;
+        }
+        else if (is_string($user) && !is_empty_string($user) && isset($HOME_DIRECTORY[$user]) && !is_empty_string($HOME_DIRECTORY[$user]))

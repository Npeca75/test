+
+        staticMcastMac OBJECT-TYPE
+           SYNTAX MacAddress
+           MAX-ACCESS read-only
+           STATUS current
+           DESCRIPTION
+               "The MAC address associated of the static MAC entry."
+           ::= { staticMcastEntry 2 }
+
+        staticMcastEgressPorts OBJECT-TYPE
+            SYNTAX      PortList (SIZE(1..28))
+            MAX-ACCESS  read-only
+            STATUS      current

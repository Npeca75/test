+           SYNTAX      Integer32 (1..50)
+           MAX-ACCESS  read-only  
+           STATUS      current 
+           DESCRIPTION 
+              "ACL Profile ID which this rule join."
+           DEFVAL  { 1 }
+           ::= { aclL2RuleEntry 2 }

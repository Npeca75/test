+                INTEGER,
+            errPortCRCErrorRX
+                Integer32,
+            errPortUndersizeRX
+                Integer32,
+            errPortOversizeRX
+                Integer32,
+            errPortFragmentRX
+                Integer32,
+            errPortJabberRX
+                Integer32,
+            errPortBufferFullDropRX
+                Integer32,
+            errPortVLANIngressDropRX
+                Integer32,
+            errPortSTPDropRX
+                Integer32,
+            errPortExcessiveDeferralTX
+                Integer32,
+            errPortCRCErrorTx

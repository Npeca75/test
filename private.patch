--- /dev/null
+++ b/private/sys/DockerStats.sh
@@ -0,0 +1,41 @@
+#!/bin/bash
+
+FILEC='/var/cache/docker.csv'
+FILEJ='/var/cache/docker.json'
+
+
+if [ "$1" != "-u" ]; then
+    if [ -f ${FILEJ} ]; then
+        cat $FILEJ
+    fi
+else
+    rm -f ${FILEJ} ${FILEC}
+    CNR=$(docker ps -q | wc -l)
+    if [ "${CNR}" -eq 0 ]; then
+        exit;
+    fi
+    JSONSTART="{\"version\":\"1\",\"data\":["
+    STAT=$(docker stats -a --no-stream|tail -n +2);
+
+    JSONROW=""
+    while IFS= read -a line; do
+        OUT=$(echo $line|xargs|sed "s/ \/ /,/g"|tr ' ' ',')
+        IMGID=$(echo $OUT|cut -d',' -f1)
+        IMG=$(docker inspect --format='{{.Config.Image}}' $IMGID|xargs)
+        TEMP=${IMG},${OUT}
+        echo ${TEMP} >> ${FILEC}
+        ARR=(${TEMP//,/ })
+        JSOND="{\"baseimg\":\"${ARR[0]}\",\"container\":\"${ARR[2]}\",\"cpu\":\"${ARR[3]}\",\"pids\":\"${ARR[11]}\""
+        JSONMEM=",\"memory\":{\"used\":\"${ARR[4]}\",\"limit\":\"${ARR[5]}\",\"perc\":\"${ARR[6]}\"}"
+        JSONNET=",\"net\":{\"rx\":\"${ARR[7]}\",\"tx\":\"${ARR[8]}\"}"
+        JSONIO=",\"io\":{\"r\":\"${ARR[9]}\",\"w\":\"${ARR[10]}\"}"
+        if [ -n "$JSONROW" ]; then
+            JSONROW=${JSONROW}","
+        fi
+        JSONROW=${JSONROW}${JSOND}${JSONMEM}${JSONNET}${JSONIO}"}"
+    done <<< "$STAT"
+    JSONEND="],\"error\":\"0\",\"errorString\":\"\"}"
+    echo ${JSONSTART}${JSONROW}${JSONEND} > ${FILEJ}
+
+    chmod 644 ${FILEJ} ${FILEC}
+fi

+                        bTrapTstReceivedWithError (1),
+                        bTrapFrameLoss (2),
+                        bTrapFrameDelay (3),
+                        bTrapDefRdiCondition (4),
+                        bTrapDefLossOfContinuity (5),
+                        bTrapDefUnexpectedPeriod (6),
+                        bTrapDefUnexpectedMep (7),
+                        bTrapDefMisMerge (8),

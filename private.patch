+                DESCRIPTION
+                    "This object indicates DHCP relay option 82 policy."
+            ::= { dhcpBOOTPRelayManagementOption82 3 }
+
+	        dhcpBOOTPRelayOption82RemoteIDType OBJECT-TYPE
+                SYNTAX  INTEGER {
+                    default(1),
+                    userdefined(2),
+                    userdefinedhex(3)
+                }
+                MAX-ACCESS  read-write

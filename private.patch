+    cpqSm2CntlrAlertStatus OBJECT-TYPE
+        SYNTAX  INTEGER {
+                other(1),
+                enabled(2),
+                disabled(3)
+                }
+        ACCESS  read-write
+        STATUS  mandatory
+        DESCRIPTION

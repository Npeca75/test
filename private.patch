+use App\Models\Ipv4Address;
+use App\Models\Ipv4Network;
+use LibreNMS\Util\IPv4;
+
+if (!is_array($pre_cache['hpe-ilo']['nicConfig'])) {
+    $pre_cache['hpe-ilo']['nicConfig'] = SnmpQuery::hidemib()->walk('CPQSM2-MIB::cpqSm2NicConfigTable')->table(1);
+}
+
+$nicConfig = $pre_cache['hpe-ilo']['nicConfig'];
+if ($nicConfig) {
+    d_echo('IPv4: hpe-ilo Addressess');
+    foreach ($nicConfig as $ifName => $ifData) {
+        if (isset($ifData['cpqSm2NicIpAddress'])) {
+            $ifIndex = 1000000 + $ifData['cpqSm2NicLocation'];
+            $portId = get_port_by_index_cache($device['device_id'], $ifIndex)['port_id'];
+            $cidr = long2cidr($ifData['cpqSm2NicIpSubnetMask']);
+            $ipv4 = new IPv4($ifData['cpqSm2NicIpAddress'] . '/' . $cidr);
+            $ipv4_network = $ipv4->getNetworkAddress() . '/' . $ipv4->cidr;
+
+            if (is_numeric($port_id)) {
+                if (Ipv4Network::where('ipv4_network', $ipv4_network)->count() < 1) {
+                    dbInsert([
+                        'ipv4_network' => $ipv4_network,
+                        'context_name' => $device['context_name']
+                    ], 'ipv4_networks');
+                    d_echo('IPv4: Create Subnet ' . $ipv4_network . PHP_EOL);
+                } else {
+                    dbUpdate(['context_name' => $device['context_name']], 'ipv4_networks', '`ipv4_network` = ?', [$ipv4_network]);
+                    d_echo('IPv4: Update Subnet ' . $ipv4_network . PHP_EOL);
+                }
+
+                $ipv4_network_id = Ipv4Network::where('ipv4_network', $ipv4_network)->value('ipv4_network_id');
+                if (Ipv4Address::where('ipv4_address', $ifData['cpqSm2NicIpAddress'])->where('ipv4_prefixlen', $cidr)->where('port_id', $port_id)->count() < 1) {
+                    dbInsert([
+                        'ipv4_address' => $ifData['cpqSm2NicIpAddress'],
+                        'ipv4_prefixlen' => $cidr,
+                        'ipv4_network_id' => $ipv4_network_id,
+                        'port_id' => $port_id,
+                        'context_name' => $device['context_name'],
+                    ], 'ipv4_addresses');
+                    d_echo('IPv4: Create Address: ' . $ifData['cpqSm2NicIpAddress'] . '/' . $cidr . ' on port:' . $port_id . PHP_EOL);
+                } else {
+                    dbUpdate(['context_name' => $device['context_name']], 'ipv4_addresses', '`ipv4_address` = ? AND `ipv4_prefixlen` = ? AND `port_id` = ?', [$ifData['cpqSm2NicIpAddress'], $cidr, $port_id]);
+                    d_echo('IPv4: Update Address: ' . $ifData['cpqSm2NicIpAddress'] . '/' . $cidr . ' context:' . $device['context_name'] . PHP_EOL);
+                }
+
+                $full_address = $ifData['cpqSm2NicIpAddress'] . '/' . $cidr . '|' . $ifIndex;
+                $valid_v4[$full_address] = 1;
+            }
+        } //end if
+    }//end foreach
+}
